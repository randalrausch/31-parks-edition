{
  "name": "31-parks-edition",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "31: National Parks Edition — a vintage WPA-inspired card game prototype.",
  "author": "Randy Rausch",
  "license": "MIT",
  "homepage": "https://github.com/randalrausch/31-parks-edition",
  "repository": {
    "type": "git",
    "url": "https://github.com/randalrausch/31-parks-edition.git"
  },
  "bugs": {
    "url": "https://github.com/randalrausch/31-parks-edition/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vite build && playwright test",
    "build:edge": "esbuild src/game/edgeEntry.ts --bundle --format=esm --platform=neutral --outfile=supabase/functions/_shared/engine.mjs",
    "setup:supabase": "./scripts/setup-supabase.sh",
    "db:push": "npx --yes supabase db push",
    "deploy:edge": "npm run build:edge && npx --yes supabase functions deploy game",
    "deploy:backend": "npm run db:push && npm run deploy:edge",
    "deploy:web": "npm run build && npx --yes netlify-cli deploy --prod --dir=dist",
    "deploy": "npm run deploy:backend && npm run deploy:web"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "esbuild": "^0.28.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.5",
    "vitest": "^3.2.6"
  }
}
