{
  "name": "31-parks-edition",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "31: National Parks Edition — a vintage WPA-inspired card game prototype.",
  "author": "Randy Rausch",
  "license": "MIT",
  "homepage": "https://github.com/randalrausch/31-parks-edition",
  "repository": {
    "type": "git",
    "url": "https://github.com/randalrausch/31-parks-edition.git"
  },
  "bugs": {
    "url": "https://github.com/randalrausch/31-parks-edition/issues"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vite build && playwright test",
    "build:edge": "esbuild src/game/edgeEntry.ts --bundle --format=esm --platform=neutral --outfile=supabase/functions/_shared/engine.mjs",
    "api:install": "npm --prefix api install",
    "api:typecheck": "npm --prefix api run typecheck",
    "api:build": "npm --prefix api run build",
    "api:test": "npm --prefix api test",
    "api:start": "npm --prefix api start",
    "azure:provision": "azd provision",
    "azure:deploy": "npm run api:build && azd deploy",
    "azure:up": "azd up",
    "dev:online:azure": "swa start http://localhost:5173 --run \"npm run dev\" --api-location http://localhost:7071",
    "supabase:setup": "./scripts/setup-supabase.sh",
    "supabase:push": "npx --yes supabase db push",
    "supabase:deploy": "npm run build:edge && npx --yes supabase functions deploy game",
    "netlify:deploy": "npm run build && npx --yes netlify-cli deploy --prod --dir=dist"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "esbuild": "^0.28.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.5",
    "vitest": "^3.2.6"
  }
}
