{
  "name": "31-parks-edition",
  "private": true,
  "version": "0.11.1",
  "type": "module",
  "description": "31: National Parks Edition \u2014 a free, open-source, WPA-inspired implementation of the card game 31.",
  "author": "Randy Rausch",
  "license": "MIT",
  "homepage": "https://github.com/randalrausch/31-parks-edition",
  "repository": {
    "type": "git",
    "url": "https://github.com/randalrausch/31-parks-edition.git"
  },
  "bugs": {
    "url": "https://github.com/randalrausch/31-parks-edition/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "postbuild": "node scripts/patch-swa-csp.mjs && node scripts/stamp-sw-cache.mjs",
    "preview": "vite preview",
    "check": "npm run format:check && npm run typecheck && npm run lint && npm test && npm run build",
    "check:all": "npm run check && npm run api:typecheck && npm run api:test && npm run edge:check && npm run test:e2e",
    "edge:check": "npm run build:edge && git diff --exit-code supabase/functions/_shared/engine.mjs",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:mutation": "stryker run",
    "fixture:state": "node scripts/gen-state-fixture.mjs",
    "test:e2e": "vite build --mode e2e && playwright test",
    "e2e:server": "esbuild e2e/localServer.ts --bundle --platform=node --format=esm --outfile=e2e/.build/localServer.mjs --log-level=warning && node e2e/.build/localServer.mjs",
    "build:edge": "esbuild src/game/edgeEntry.ts --bundle --format=esm --platform=neutral --outfile=supabase/functions/_shared/engine.mjs",
    "api:install": "npm --prefix api install",
    "api:typecheck": "npm --prefix api run typecheck",
    "api:build": "npm --prefix api run build",
    "api:test": "npm --prefix api test",
    "api:start": "npm --prefix api start",
    "azure:provision": "azd provision",
    "azure:deploy": "npm run api:build && azd deploy",
    "azure:up": "azd up",
    "dev:online:azure": "swa start http://localhost:5173 --run \"npm run dev\" --api-location http://localhost:7071",
    "supabase:setup": "./scripts/setup-supabase.sh",
    "supabase:push": "npx --yes supabase db push",
    "supabase:deploy": "npm run build:edge && npx --yes supabase functions deploy game",
    "netlify:deploy": "npm run build && npx --yes netlify-cli deploy --prod --dir=dist",
    "test:e2e:deploy": "playwright test --config=playwright.deploy.config.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.20.0",
    "@playwright/test": "^1.61.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild": "0.28.1",
    "eslint": "^9.20.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "happy-dom": "^20.10.6",
    "prettier": "^3.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.24.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
