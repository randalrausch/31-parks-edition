{
  "$schema": "https://json.schemastore.org/staticwebapp.config.json",
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/*",
      "*.{webp,png,jpg,svg,ico,wav,mp3,json,txt,webmanifest}"
    ]
  },
  "mimeTypes": {
    ".webmanifest": "application/manifest+json"
  }
}
