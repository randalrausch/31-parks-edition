# Loaded by `vite build --mode e2e` (the test:e2e script). Bakes the local
# in-memory game server (e2e/localServer.ts, started by Playwright's webServer)
# in as the online backend, so the E2E suite can play a real two-browser online
# round at PR time with no cloud credentials. Never used by `npm run build`.
VITE_API_BASE=http://127.0.0.1:8787/api
