# Logs
logs
*.log
npm-debug.log*

node_modules
dist
dist-ssr
coverage
*.local

# Editor
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Local Netlify folder
.netlify

# TypeScript incremental build cache
*.tsbuildinfo

# Azure Developer CLI (azd) per-environment state — holds subscription ID,
# region, and any `azd env set` values (budget email, custom domain, etc.).
# Never commit this, especially on a public repo.
.azure/

# Local Azurite (Table Storage emulator) state
.azurite/

# Azure Functions local settings (may hold secrets)
api/local.settings.json

# Claude Code: track the SHARED config (settings.json, agents/, commands/,
# hooks/) as part of the project, but ignore machine-specific and runtime state.
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/*.local.json

# Supabase CLI local state
supabase/.temp/
supabase/.branches/

# Local dev tooling (not part of the project)
.mcp.json

# Playwright E2E artifacts
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
# esbuild output of the local E2E game server (e2e/localServer.ts)
/e2e/.build/

# Superpowers-generated planning docs (kept local, not tracked)
/docs/superpowers/plans/

# Transient files written by scripts/release.mjs
.release-notes.md
.release-ambiguous.md
