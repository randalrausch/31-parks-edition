# EditorConfig — consistent whitespace across editors and agents.
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
# Markdown uses trailing spaces for hard line breaks.
trim_trailing_whitespace = false

[*.{png,webp,jpg,jpeg,ico,mp3,wav,svg}]
# Binary/asset files: don't let editors normalize them.
insert_final_newline = false
trim_trailing_whitespace = false
